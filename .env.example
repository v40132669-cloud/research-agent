MODEL_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# 使用阿里云百炼 OpenAI 兼容接口时，可按下面方式配置：
# OPENAI_API_KEY=your_dashscope_api_key
# OPENAI_MODEL=qwen3-max
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# MODEL_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# 阿里云百炼 Qwen 配置（使用 MODEL_PROVIDER=qwen 时）
# MODEL_PROVIDER=qwen
# DASHSCOPE_API_KEY=your_dashscope_api_key
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen3-max

# 讯飞星火配置（使用 MODEL_PROVIDER=xunfei 时）
# XUNFEI_APP_ID=your_app_id
# XUNFEI_API_KEY=your_apikey:your_apisecret
# XUNFEI_BASE_URL=wss://spark-api.xf-yun.com/v1.1/chat
# XUNFEI_MODEL=general

TAVILY_API_KEY=your_tavily_api_key
TAVILY_MAX_RESULTS=8
TAVILY_TOP_K=5
LANGGRAPH_DEBUG=false
LANGGRAPH_CHECKPOINT_DB=agent_state.db

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=research-agent
